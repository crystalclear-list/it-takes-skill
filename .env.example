# THESTEELEZONE — n8n webhook auth tokens
# Copy this to .env and fill in your actual token values.
# NEVER commit .env — it is in .gitignore.
# Each token is the Bearer token n8n expects on the matching webhook.

# Content endpoints
N8N_WEBHOOK_TOKEN_TIKTOK=
N8N_WEBHOOK_TOKEN_IG=
N8N_WEBHOOK_TOKEN_X=
N8N_WEBHOOK_TOKEN_FACEBOOK=
N8N_WEBHOOK_TOKEN_CAPTION=
N8N_WEBHOOK_TOKEN_OF_NURTURE=

# Infra endpoints (single token covers both infra__ webhooks)
N8N_WEBHOOK_TOKEN_INFRA=

# Reporting
N8N_WEBHOOK_TOKEN_REPORTING=
