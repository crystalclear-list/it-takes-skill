# -----------------------------
# Core ignores
# -----------------------------
node_modules/
.env
*.env
.DS_Store

# -----------------------------
# Logs
# -----------------------------
# Ignore all logs by default
logs/*

# But DO track workflow logs
!logs/workflows/
!logs/workflows/*.log

# -----------------------------
# Reports
# -----------------------------
# Track all reports
!reports/

# -----------------------------
# Build artifacts
# -----------------------------
dist/
build/
.cache/
.tmp/

# -----------------------------
# Editor / OS noise
# -----------------------------
*.swp
*.swo
*.tmp
Thumbs.db

# -----------------------------
# Backup files
# -----------------------------
*~
