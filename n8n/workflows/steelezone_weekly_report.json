        660,
        300
      ],
      "parameters": {
        "jsCode": "// Weekly summary placeholder\n// Replace with your reporting logic:\n//   - Query n8n execution history\n//   - Count successes / failures per platform\n//   - Write summary to a Google Sheet, Notion, or email\nconst { report_period, trigger_reason } = $json;\nconsole.log(`Weekly report triggered: ${report_period} \u2014 ${trigger_reason}`);\nreturn [{ json: { status: 'report_placeholder', report_period, trigger_reason } }];",
        "mode": "runOnceForAllItems"
      }
    },
