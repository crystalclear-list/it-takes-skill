      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        300
      ],
      "parameters": {
        "jsCode": "// Auth check \u2014 validates Bearer token from Authorization header\nconst auth = $input.first().json.headers?.authorization || '';\nconst token = process.env.N8N_WEBHOOK_TOKEN_REPORTING || '';\nif (!token) throw new Error('Env var N8N_WEBHOOK_TOKEN_REPORTING is not set');\nif (auth !== 'Bearer ' + token) {\n  throw new Error('Unauthorized: invalid or missing Bearer token');\n}\nreturn $input.all();",
        "mode": "runOnceForAllItems"
      }
    },
    {
      "id": "5e313564-df38-4e38-bf5e-d44cff8ee1a4",
      "name": "Build Report",
      "type": "n8n-nodes-base.code",
