{
  "agent_id": "AGENT-ORCHESTRATOR-001",
  "name": "Orchestrator Agent",
  "role": "orchestrator",
  "description": "Coordinates the five core agents (Repo, Workflow, Audit, Manifest, Reporting) to execute governed multi-step operations. Calls agents by role only. Enforces human approval on all cross-agent operations that are financial, infrastructure, or irreversible. Never executes actions directly — only routes, sequences, and gates.",
  "owner": "os-core",
  "environment": "local",
  "risk_level": "high",

  "capabilities": [
    "agent_routing",
    "cross_agent_sequencing",
    "human_approval_gate",
    "escalation_handling",
    "provenance_stitching"
  ],

  "skills_required": [
    "system/workflow_orchestrate",
    "meta/intent_verification",
    "meta/risk_assessment",
    "meta/escalation_router",
    "meta/provenance_tracker"
  ],

  "callable_agents": [
    {
      "agent_id": "AGENT-REPO-001",
      "role": "repo_maintenance",
      "call_conditions": ["repo_change_required", "gitignore_update", "file_staging"],
      "approval_required": false
    },
    {
      "agent_id": "AGENT-WORKFLOW-001",
      "role": "workflow_executor",
      "call_conditions": ["workflow_manifest_loaded", "parameters_validated"],
      "approval_required": false
    },
    {
      "agent_id": "AGENT-AUDIT-001",
      "role": "audit_enforcer",
      "call_conditions": ["workflow_artifacts_ready", "pre_delivery_required"],
      "approval_required": false
    },
    {
      "agent_id": "AGENT-MANIFEST-001",
      "role": "manifest_editor",
      "call_conditions": ["schema_change_requested", "new_manifest_required"],
      "approval_required": true,
      "approval_triggers": ["schema_changes", "governance_modifications", "permission_elevation"]
    },
    {
      "agent_id": "AGENT-REPORTING-001",
      "role": "report_generator",
      "call_conditions": ["audit_complete", "artifacts_available"],
      "approval_required": false
    }
  ],

  "tool_constraints": {
    "allowed_tools": [
      "agent_invoke",
      "approval_gate",
      "escalation_trigger",
      "provenance_read",
      "log_reader"
    ],
    "denied_tools": [
      "direct_file_write",
      "direct_payment",
      "shell_exec",
      "database_write",
      "agent_impersonate"
    ]
  },

  "inputs": {
    "goal": {
      "type": "string",
      "description": "High-level goal or workflow trigger from human or upstream system."
    },
    "context": {
      "type": "object",
      "description": "Session context: workflow_id, parameters, prior artifacts, approval state."
    }
  },

  "outputs": {
    "orchestration_summary": "string",
    "agent_call_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "agent_id": "string",
          "called_at": "string",
          "outcome": "string",
          "artifacts_produced": {
            "type": "array",
            "items": "string"
          }
        }
      }
    },
    "pending_approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "approval_id": "string",
          "agent_id": "string",
          "action": "string",
          "risk_level": "string",
          "expires_at": "string"
        }
      }
    },
    "provenance_id": "string"
  },

  "execution_policy": {
    "default_sequence": [
      "intent_verification",
      "risk_assessment",
      "agent_routing",
      "cross_agent_execution",
      "audit_gate",
      "report_generation",
      "provenance_write"
    ],
    "parallel_execution_allowed": false,
    "max_concurrent_agents": 1,
    "retry_policy": {
      "max_retries": 2,
      "retry_on": ["transient_failure", "timeout"],
      "no_retry_on": ["governance_violation", "human_rejection", "safety_halt"]
    }
  },

  "approval_gates": {
    "cross_agent_financial": {
      "trigger": "any_agent_produces_financial_action",
      "approver_role": "owner",
      "approval_type": "single",
      "sla_minutes": 60,
      "on_timeout": "escalate_and_halt"
    },
    "cross_agent_infrastructure": {
      "trigger": "any_agent_requests_infrastructure_change",
      "approver_role": "owner",
      "approval_type": "single",
      "sla_minutes": 120,
      "on_timeout": "halt"
    },
    "cross_agent_governance": {
      "trigger": "manifest_agent_proposes_schema_change",
      "approver_role": "owner",
      "approval_type": "dual",
      "sla_minutes": 2880,
      "on_timeout": "halt"
    }
  },

  "escalation_rules": {
    "safety_violation": {
      "route_to": "human",
      "halt_pipeline": true,
      "log_security_event": true
    },
    "audit_failure": {
      "route_to": "AGENT-AUDIT-001",
      "retry_allowed": true,
      "max_retries": 1
    },
    "approval_timeout": {
      "route_to": "human",
      "halt_pipeline": true,
      "notify": true
    },
    "agent_unavailable": {
      "route_to": "human",
      "halt_pipeline": true
    }
  },

  "safety": {
    "halt_on_violation": true,
    "requires_human_approval": [
      "financial_actions",
      "infrastructure_mutations",
      "governance_file_changes",
      "schema_modifications",
      "permission_elevation",
      "cross_agent_irreversible_chain"
    ],
    "forbidden_patterns": [
      "agent_calls_self",
      "orchestrator_executes_directly",
      "approval_bypass",
      "audit_skip"
    ],
    "max_pipeline_depth": 5,
    "max_total_runtime_seconds": 3600
  },

  "logging": {
    "log_level": "info",
    "log_all_agent_calls": true,
    "log_all_approval_decisions": true,
    "log_escalations": true,
    "attach_provenance_id": true,
    "audit_file": "logs/workflows/orchestrator.log"
  },

  "governance_ref": "governance/charter.yaml",
  "safety_rules_ref": "governance/safety-rules.md",
  "inter_agent_protocol_ref": "governance/inter_agent_protocol.md"
}
