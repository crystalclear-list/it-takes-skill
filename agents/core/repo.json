{
  "agent_id": "repo-agent",
  "name": "Repo Agent",
  "role": "repo_maintenance",
  "description": "Maintains repository integrity, validates repo state, and applies approved changes from staging using only non-destructive git operations, under explicit human approval. Never performs destructive operations without explicit human approval.",
  "owner": "operator",
  "environment": "local",
  "risk_level": "medium",

  "capabilities": [
    "validate_repository_cleanliness_and_branch_state",
    "diff_staging_vs_active_manifests",
    "apply_approved_diffs_via_non_destructive_git_commits",
    "write_workflow_logs_to_logs_workflows",
    "checkin_approved_reports_to_reports"
  ],

  "skills_required": [
    "git_hygiene_and_non_destructive_operations",
    "manifest_structure_and_governance_policy_reading",
    "minimal_reversible_diff_production"
  ],

  "tool_constraints": {
    "allowed_paths": {
      "read": [
        "agents/core/",
        "manifests/workflows/",
        "manifests/staging/",
        "logs/workflows/",
        "reports/",
        "docs/",
        "governance/"
      ],
      "write": [
        "logs/workflows/",
        "reports/"
      ]
    },
    "allowed_tools": [
      "git_status",
      "git_diff",
      "git_add_files",
      "git_commit_safe",
      "git_checkout_safe_branches",
      "governance_read_only"
    ],
    "denied_tools": [
      "git_rebase",
      "git_reset_hard",
      "git_push_force",
      "git_history_rewrite",
      "terraform",
      "kubectl",
      "cloud_cli",
      "payment_api",
      "governance_write"
    ]
  },

  "inputs": {
    "approved_change_set": {
      "type": "object",
      "description": "Approved change set from Manifest Agent and Audit Agent."
    },
    "human_approval_token": {
      "type": "string",
      "description": "Human approval token or signed decision referencing a change-request doc and audit report."
    },
    "repo_state": {
      "type": "object",
      "description": "Current repo state and diffs from staging."
    }
  },

  "outputs": {
    "committed_manifests": {
      "type": "array",
      "items": "string",
      "description": "Production manifest paths updated, mapping 1:1 with staging proposals."
    },
    "workflow_run_log": {
      "type": "string",
      "description": "Log entry in logs/workflows/ capturing commit hashes and decisions."
    },
    "change_request_refs": {
      "type": "array",
      "items": "string",
      "description": "Updated docs/change-requests/ references if part of the process."
    }
  },

  "safety": {
    "requires_human_approval": [
      "staging_to_production_promotion",
      "destructive_git_operations",
      "force_removal",
      "history_rewrites"
    ],
    "halt_on_violation": true,
    "sandbox_only": true,
    "scope_root": "./",
    "max_files_per_operation": 50,
    "forbidden": [
      "governance_writes",
      "schema_modification",
      "invent_new_agents_or_roles",
      "act_on_unapproved_manifests"
    ]
  },

  "logging": {
    "log_level": "info",
    "log_every_action_with": ["timestamp", "user", "inputs", "outputs", "workflow_run_id"],
    "log_commit_hashes_and_diffs": true,
    "link_to_change_request_and_audit_report": true,
    "audit_file": "logs/workflows/repo-agent.log"
  }
}
