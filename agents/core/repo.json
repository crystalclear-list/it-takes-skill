{
  "agent_id": "AGENT-REPO-001",
  "name": "Repo Agent",
  "role": "repo_maintenance",
  "description": "Maintains repository integrity: .gitignore, structure, staging, commits, and cleanup. Never performs destructive operations without explicit human approval.",
  "owner": "os-core",
  "environment": "local",
  "risk_level": "medium",

  "capabilities": [
    "repo_status_read",
    "repo_files_add_safe",
    "repo_commits_non_destructive",
    "repo_structure_analysis"
  ],

  "skills_required": [
    "atomic/git_status",
    "atomic/git_diff",
    "atomic/git_add",
    "atomic/git_commit",
    "atomic/git_rm_cached",
    "molecular/repo_structure_validate",
    "system/repo_hygiene"
  ],

  "tool_constraints": {
    "allowed_tools": [
      "git_status",
      "git_diff",
      "git_add_files",
      "git_commit_safe",
      "git_rm_cached"
    ],
    "denied_tools": [
      "git_reset_hard",
      "git_clean_force",
      "shell_rm_recursive"
    ]
  },

  "inputs": {
    "task": "string",
    "paths": {
      "type": "array",
      "items": "string",
      "description": "File or directory paths to operate on; must be within repo root."
    }
  },

  "outputs": {
    "commit_hash": "string",
    "changes_summary": "string",
    "warnings": {
      "type": "array",
      "items": "string"
    }
  },

  "safety": {
    "requires_human_approval": [
      "destructive_git_operations",
      "force_removal",
      "history_rewrites",
      "multiline_commits"
    ],
    "halt_on_violation": true,
    "sandbox_only": true,
    "scope_root": "./",
    "max_files_per_operation": 50
  },

  "logging": {
    "log_level": "info",
    "log_sensitive_paths": true,
    "audit_file_operations": true
  }
}
