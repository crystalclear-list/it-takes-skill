{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crystalclear.ai/schemas/approval-manifest/1.0.0",
  "title": "Money Key Approval Manifest",
  "description": "Schema for bundled approval manifests submitted to the Money Key human execution layer. All financial and irreversible actions must be packaged in this format before human review.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "manifest_id",
    "created_at",
    "prepared_by",
    "session_id",
    "summary",
    "actions",
    "risk_assessment",
    "alternatives",
    "approval_required"
  ],
  "additionalProperties": false,
  "properties": {
    "manifest_id": {
      "type": "string",
      "description": "Unique identifier for this manifest. Format: MNF-{uuid}",
      "pattern": "^MNF-[a-f0-9-]{36}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp when this manifest was created"
    },
    "prepared_by": {
      "type": "string",
      "description": "Identity of the Finance-Prep agent that produced this manifest"
    },
    "session_id": {
      "type": "string",
      "description": "Pipeline or session this manifest belongs to"
    },
    "summary": {
      "type": "string",
      "description": "Human-readable one-paragraph summary of all actions in this manifest",
      "maxLength": 500
    },
    "actions": {
      "type": "array",
      "description": "Ordered list of actions requiring approval",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["action_id", "type", "description", "payload", "reversible", "estimated_impact"],
        "additionalProperties": false,
        "properties": {
          "action_id": {
            "type": "string",
            "description": "Unique identifier for this action within the manifest"
          },
          "type": {
            "type": "string",
            "enum": [
              "financial_transfer",
              "contract_signing",
              "credential_change",
              "production_deployment",
              "data_deletion",
              "external_api_call",
              "email_send",
              "other_irreversible"
            ],
            "description": "Category of irreversible action"
          },
          "description": {
            "type": "string",
            "description": "Clear, plain-language description of what this action does",
            "maxLength": 300
          },
          "payload": {
            "type": "object",
            "description": "Exact parameters for the action. Structure varies by action type.",
            "properties": {
              "amount": {
                "type": "number",
                "description": "For financial actions: exact amount in base currency units"
              },
              "currency": {
                "type": "string",
                "description": "ISO 4217 currency code",
                "pattern": "^[A-Z]{3}$"
              },
              "recipient": {
                "type": "string",
                "description": "Recipient identifier (account, address, or name)"
              },
              "endpoint": {
                "type": "string",
                "description": "API endpoint or system target for the action"
              },
              "method": {
                "type": "string",
                "enum": ["POST", "PUT", "DELETE", "PATCH"],
                "description": "HTTP method for API actions"
              },
              "body": {
                "type": "object",
                "description": "Request body for API actions"
              },
              "notes": {
                "type": "string",
                "description": "Additional context for this payload"
              }
            }
          },
          "reversible": {
            "type": "boolean",
            "description": "Whether this action can be undone after execution"
          },
          "estimated_impact": {
            "type": "object",
            "required": ["financial", "operational", "reputational"],
            "properties": {
              "financial": {
                "type": "string",
                "description": "Estimated financial impact",
                "enum": ["none", "low", "medium", "high", "critical"]
              },
              "operational": {
                "type": "string",
                "description": "Estimated operational impact",
                "enum": ["none", "low", "medium", "high", "critical"]
              },
              "reputational": {
                "type": "string",
                "description": "Estimated reputational impact",
                "enum": ["none", "low", "medium", "high", "critical"]
              }
            }
          },
          "dependencies": {
            "type": "array",
            "items": {"type": "string"},
            "description": "action_ids this action depends on (must be approved first)"
          }
        }
      }
    },
    "risk_assessment": {
      "type": "object",
      "required": ["overall_risk_level", "risk_score", "flags", "go_no_go"],
      "properties": {
        "overall_risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "risk_score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "flags": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["dimension", "description", "severity"],
            "properties": {
              "dimension": {
                "type": "string",
                "enum": ["privacy", "accuracy", "reversibility", "scope", "harm_potential", "compliance"]
              },
              "description": {"type": "string"},
              "severity": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low"]
              },
              "mitigation": {"type": "string"}
            }
          }
        },
        "go_no_go": {
          "type": "string",
          "enum": ["go", "go_with_conditions", "no_go"]
        },
        "conditions": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Required mitigations if go_no_go is go_with_conditions"
        }
      }
    },
    "alternatives": {
      "type": "array",
      "description": "Alternative approaches that avoid or reduce the irreversible actions",
      "items": {
        "type": "object",
        "required": ["description", "tradeoff"],
        "properties": {
          "description": {"type": "string"},
          "tradeoff": {"type": "string"}
        }
      }
    },
    "approval_required": {
      "type": "object",
      "required": ["approver_role", "approval_type", "sla_minutes"],
      "properties": {
        "approver_role": {
          "type": "string",
          "description": "Role required to approve (e.g., owner, cfo, cto)"
        },
        "approval_type": {
          "type": "string",
          "enum": ["single", "dual"],
          "description": "single = one approver; dual = two approvers required"
        },
        "sla_minutes": {
          "type": "integer",
          "minimum": 1,
          "description": "Minutes until this manifest expires if not acted on"
        },
        "co_approver_role": {
          "type": "string",
          "description": "Second approver role required for dual approval"
        }
      }
    },
    "auditor_sign_off": {
      "type": "object",
      "description": "Auditor Agent review result — must be present before Money Key review",
      "required": ["verdict", "auditor_id", "reviewed_at"],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["approved", "approved_with_conditions", "rejected"]
        },
        "auditor_id": {"type": "string"},
        "reviewed_at": {"type": "string", "format": "date-time"},
        "conditions": {
          "type": "array",
          "items": {"type": "string"}
        },
        "notes": {"type": "string"}
      }
    },
    "provenance": {
      "type": "object",
      "description": "Lineage of this manifest",
      "properties": {
        "source_session_id": {"type": "string"},
        "planner_plan_id": {"type": "string"},
        "executor_task_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "skill_audit_trail_ref": {"type": "string"}
      }
    },
    "execution_record": {
      "type": "object",
      "description": "Populated by Money Key after human execution — read-only post-approval",
      "properties": {
        "approved_by": {"type": "string"},
        "approved_at": {"type": "string", "format": "date-time"},
        "executed_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "action_id": {"type": "string"},
              "executed_at": {"type": "string", "format": "date-time"},
              "outcome": {"type": "string", "enum": ["success", "failed", "skipped"]},
              "notes": {"type": "string"}
            }
          }
        },
        "override_justification": {
          "type": "string",
          "description": "Required if any action with go_no_go: no_go was executed"
        }
      }
    }
  }
}
